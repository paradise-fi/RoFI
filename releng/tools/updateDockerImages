#!/usr/bin/env bash
set -euo pipefail

image_prefix="${IMAGE_PREFIX:-ghcr.io/paradise-fi}"

docker build --pull \
    -t "${image_prefix}/rofi:latest" \
    -t "${image_prefix}/rofi.debian:latest" \
    .
docker push "${image_prefix}/rofi:latest"
docker push "${image_prefix}/rofi.debian:latest"

docker build --pull -t "${image_prefix}/rofi.ubuntu:latest" --build-arg BASE=ubuntu:24.04 .
docker push "${image_prefix}/rofi.ubuntu:latest"

docker build --pull -t "${image_prefix}/rofi.doc:latest" -f Dockerfile.doc .
docker push "${image_prefix}/rofi.doc:latest"
