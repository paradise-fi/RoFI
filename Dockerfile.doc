FROM debian:bookworm

SHELL ["/bin/bash", "-c"]

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        ca-certificates \
        cmake \
        doxygen \
        g++ \
        gcc \
        git \
        graphviz \
        make \
        python3 \
        python3-pip && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install --break-system-packages \
        sphinx==7.4.7 \
        breathe==4.35.0 \
        myst-parser==3.0.1 \
        sphinx-rtd-theme==2.0.0

RUN doxygen --version && \
    sphinx-build --version && \
    python3 -c "import breathe, myst_parser, sphinx_rtd_theme"

CMD ["bash"]
