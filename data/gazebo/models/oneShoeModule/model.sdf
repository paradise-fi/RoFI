    <model name='oneShoeModule'>
        <link name='shoe'>
            <self_collide>false</self_collide>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>4e-04</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>4e-04</iyy>
                    <iyz>0</iyz>
