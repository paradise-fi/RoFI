            <collision name='shoe-collision'>
                <geometry>
                    <mesh>
                        <uri>model://oneShoeModule/meshes/model.obj</uri>
                        <scale>0.001 0.001 0.001</scale>
                        <!-- <submesh>
                            <name>shoe</name>
                        </submesh> -->
                    </mesh>
                </geometry>
            </collision>
            <visual name='shoe-visual'>
                <pose>0 0 0 0 0 0</pose>
