<sdf version='1.6'>
  <world name='default'>
    <!-- Remove gravity -->
    <gravity>0 0 0</gravity>

    <!-- A global light source -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Distributor plugin -->
    <plugin name='rofi::sim::systems::RofiDistributorPlugin' filename='distributorPlugin'/>

    <!-- Attacher plugin -->
    <plugin name='rofi::sim::systems::AttacherPlugin' filename='attacherPlugin'/>
  </world>
</sdf>
